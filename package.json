{
	"name": "ess-admin-ds",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"deploy:prod": "wrangler deploy --env production",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest run",
		"format:check": "prettier --check package.json .prettierrc .vscode/settings.json .github/workflows/ci.yml wrangler.jsonc knowledge/adr/*.md",
		"validate:website-template": "node ./scripts/validate-website-template.js",
		"check:tenant:failopen": "bash ./scripts/validate-tenant-isolation.sh --check=failopen",
		"check:tenant:sql": "bash ./scripts/validate-tenant-isolation.sh --check=sql",
		"ci:verify": "npm run test && npm run check:tenant:failopen && npm run check:tenant:sql",
		"ci:strict": "bash ./scripts/validate-tenant-isolation.sh",
		"ci:structure": "bash ./scripts/validate-structure.sh",
		"ci:tenant": "bash ./scripts/validate-tenant-isolation.sh",
		"ci:hygiene": "npm run lint && npm run format:check",
		"ci": "npm run ci:structure && npm run ci:tenant && npm run ci:hygiene && npm run validate:website-template && npm run test",
		"secrets:set": "./scripts/set-wrangler-secrets.sh",
		"secrets:set:prod": "./scripts/set-wrangler-secrets.sh production",
		"lint": "eslint src test scripts . --ext .js,.mjs,.cjs",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.71",
		"eslint": "^8.57.1",
		"prettier": "^3.8.1",
		"vitest": "~3.2.0",
		"wrangler": "^4.35.0"
	}
}
