export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);



    const MAX_VISUAL_LANES_RUNTIME =
      Number(env.MAX_VISUAL_LANES || 40) || 40;


    let AREA_CAPACITY_BLOCKS_RUNTIME = {
  indoor: 12,
  outdoor: 10,
  garden: 8,
  bar: 6
};

try {
  const raw = env?.AREA_CAPACITY_BLOCKS;

  if (raw) {
    if (typeof raw === "string") {
      const parsed = JSON.parse(raw);
      if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
        AREA_CAPACITY_BLOCKS_RUNTIME = parsed;
      }
    } else if (typeof raw === "object" && !Array.isArray(raw)) {
      AREA_CAPACITY_BLOCKS_RUNTIME = raw;
    }
  }
} catch (e) {
  console.log("AREA_CAPACITY_BLOCKS parse failed:", e?.message || e);
}

const DEFAULT_AREA_CAPACITY_BLOCKS_RUNTIME =
  Number(env.DEFAULT_AREA_CAPACITY_BLOCKS || 40) || 40;


    const corsHeaders = {
  "Access-Control-Allow-Origin": request.headers.get("Origin") || "*",
  "Access-Control-Allow-Methods": "GET,POST,OPTIONS",
  "Access-Control-Allow-Headers": "Content-Type"
};


    if (request.method === "OPTIONS") {
      return new Response(null, { headers: corsHeaders });
    }


    // Fallback tạm để không bị khóa ngoài hệ thống nếu env chưa load
    const STAFF_DATA_FALLBACK = [
  { id: "u1", name: "Hostess", pin: "1111", role: "staff" },
  { id: "u2", name: "Manager", pin: "8888", role: "manager" },
  { id: "u3", name: "Admin", pin: "1234", role: "admin" },
  { id: "u4", name: "Anna", pin: "7878" }
];

let STAFF_DATA = STAFF_DATA_FALLBACK;

try {
  const rawStaff = env?.STAFF_DATA;

  if (typeof rawStaff === "string" && rawStaff.trim()) {
    const parsed = JSON.parse(rawStaff);

    if (Array.isArray(parsed) && parsed.length > 0) {
      STAFF_DATA = parsed
        .filter(u => u && typeof u === "object")
        .map(u => ({
          id: String(u.id || "").trim(),
          name: String(u.name || "").trim(),
          pin: String(u.pin || "").trim(),
          role: String(u.role || "staff").trim()
        }))
        .filter(u => u.name && u.pin);
    }
  }
} catch (e) {
  // giữ fallback, không làm worker chết
}

    if (url.pathname === "/api/auth") {
      const pin = String(url.searchParams.get("pin") || "").trim();


      const user = STAFF_DATA.find(
        u => String(u.pin || "").trim() === pin
      );


      return jsonResponse(
        user
          ? {
              success: true,
              user: user.name,
              staff: STAFF_DATA.map(s => s.name)
            }
          : {
              success: false,
              debug_pin: pin,
              debug_staff_count: STAFF_DATA.length,
              debug_env_present: !!(env && env.STAFF_DATA)
            },
        user ? 200 : 401,
        corsHeaders
      );
    }


    function boardKey(date) {
  return "board:" + date;
}

// ---------- KV TEST ----------

    if (url.pathname === "/api/config-debug") {
      return jsonResponse({
        has_env_area_capacity_blocks: !!env.AREA_CAPACITY_BLOCKS,
        raw_area_capacity_blocks: env.AREA_CAPACITY_BLOCKS || null,
        parsed_area_capacity_blocks_runtime: AREA_CAPACITY_BLOCKS_RUNTIME,
        default_area_capacity_blocks_runtime: DEFAULT_AREA_CAPACITY_BLOCKS_RUNTIME
      }, 200, corsHeaders);
    }

    if (url.pathname === "/api/kv-test") {
      await env.ESSKULTUR_BOARD.put("test","hello");
      const v = await env.ESSKULTUR_BOARD.get("test");

      return jsonResponse({ success:true, value:v },200,corsHeaders);
    }

    function bookingIdentityKey(b) {
  const id = String(b?.booking_id || "").trim();
  if (id) return "id:" + id;

  return [
    "fallback",
    String(b?.guest_name || "").trim().toLowerCase(),
    String(b?.date || "").trim(),
    String(b?.time || "").trim(),
    String(b?.phone || "").trim()
  ].join("|");
}

function bookingTs(b) {
  return new Date(b?.updated_at || b?.submitted_at || 0).getTime() || 0;
}

     // ---------- BOARD SYNC ----------
    if (url.pathname === "/api/board-sync" && request.method === "POST") {

      const body = await request.json();
      const booking = body.booking || body;

      if (!booking.date) {
        return jsonResponse(
          { success:false, error:"Invalid booking: missing date" },
          400,
          corsHeaders
        );
      }

      const key = "board:" + booking.date;

      const snapshot =
        await env.ESSKULTUR_BOARD.get(key,"json") ||
        { bookings:[], revision:0 };

      const incomingKey = bookingIdentityKey(booking);
      const incomingTs = bookingTs(booking);

      const idx = snapshot.bookings.findIndex(b => {
        const sameId =
          String(b?.booking_id || "").trim() &&
          String(booking?.booking_id || "").trim() &&
          String(b.booking_id) === String(booking.booking_id);

        const sameFallback = bookingIdentityKey(b) === incomingKey;

        return sameId || sameFallback;
      });

      if (idx >= 0) {
        const existing = snapshot.bookings[idx];
        const existingTs = bookingTs(existing);

        if (incomingTs >= existingTs) {
          snapshot.bookings[idx] = {
            ...existing,
            ...booking
          };
        }
      } else {
        snapshot.bookings.push(booking);
      }

      // dedupe mạnh lần cuối để cắt clone cũ
      const map = new Map();
      for (const b of snapshot.bookings) {
        const k = bookingIdentityKey(b);
        const prev = map.get(k);
        if (!prev || bookingTs(b) >= bookingTs(prev)) {
          map.set(k, b);
        }
      }
      snapshot.bookings = Array.from(map.values());

      snapshot.revision++;
      snapshot.updated_at = new Date().toISOString();

      await env.ESSKULTUR_BOARD.put(key, JSON.stringify(snapshot));

      return jsonResponse(
        { success:true, revision:snapshot.revision, count:snapshot.bookings.length },
        200,
        corsHeaders
      );
    }

    // ---------- BOARD LIST ----------
    if (url.pathname === "/api/list") {

      const date = url.searchParams.get("date");

      const snapshot =
        await env.ESSKULTUR_BOARD.get("board:"+date,"json") ||
        { bookings:[], revision:0 };

      return jsonResponse(snapshot,200,corsHeaders);
    }

    //-------------API CREATE----------

    if (url.pathname === "/api/create" && request.method === "POST") {
  try {
    const incoming = await request.formData();

    const guest_name = String(incoming.get("guest_name") || "").trim();
    const phone = String(incoming.get("phone") || "").trim();
    const pax = Number(incoming.get("pax") || 0);
    const date = String(incoming.get("date") || "").trim();
    const time = String(incoming.get("time") || "").trim();
    const duration = Number(incoming.get("duration") || 120);
    const area = String(incoming.get("area") || "indoor").trim().toLowerCase();
    const flag = String(incoming.get("flag") || "").trim().toLowerCase();
    const staff_user = String(incoming.get("staff_user") || "").trim();
    const notes = String(incoming.get("notes") || "").trim();
    const created_by = String(incoming.get("created_by") || "").trim();

    if (!guest_name || !date || !time || !pax) {
      return jsonResponse({
        success: false,
        error: "Missing required fields",
        required: ["guest_name", "pax", "date", "time"]
      }, 400, corsHeaders);
    }

    const bookingDateTime = new Date(date + "T" + time);

    if (Number.isNaN(bookingDateTime.getTime())) {
      return jsonResponse({
        success: false,
        error: "Invalid date/time"
      }, 400, corsHeaders);
    }

    if (bookingDateTime.getTime() < Date.now()) {
      return jsonResponse({
        success: false,
        error: "Past bookings are not allowed"
      }, 400, corsHeaders);
    }

    const outbound = {
      source: "onsite",
      guest_name,
      contact_name: guest_name,
      phone,
      pax,
      blocks: Math.max(1, Math.ceil(pax / 2)),
      date,
      start_at: time,
      time,
      duration,
      staff_user,
      staff: staff_user,
      area: area || "indoor",
      flag,
      notes,
      created_by,
      updated_by: created_by
    };

    const fd = new FormData();
    Object.entries(outbound).forEach(([k, v]) => {
      fd.append(k, v == null ? "" : String(v));
    });

    // compatibility aliases for Make
    fd.append("name", guest_name);
    fd.append("guests", String(pax));
    fd.append("worker_secret", env.WORKER_SECRET || "my-super-secret");
    fd.append("payload_json", JSON.stringify(outbound));

    const baseUrl = (
      env.MAKE_CREATE_URL ||
      "https://hook.eu1.make.com/snewlt3wj9evwebw2mo5z2i75apox7bf"
    ).trim();

    const makeUrl = baseUrl + (baseUrl.includes("?") ? "&" : "?") + "_t=" + Date.now();

    const makeRes = await fetch(makeUrl, {
      method: "POST",
      body: fd
    });

    const makeText = await makeRes.text();

    if (!makeRes.ok) {
      return jsonResponse({
        success: false,
        error: "Make rejected booking",
        make_status: makeRes.status,
        make_response: makeText
      }, 502, corsHeaders);
    }

    return jsonResponse({
      success: true,
      accepted: true,
      message: "Booking accepted by Make. Waiting for board sync.",
      make_status: makeRes.status,
      make_response: makeText
    }, 200, corsHeaders);

  } catch (e) {
    return jsonResponse({
      success: false,
      error: e.message || String(e),
      where: "/api/create"
    }, 500, corsHeaders);
  }
}


    if (url.pathname === "/") {
  const html = renderHTMLPage({
    maxVisualLanes: MAX_VISUAL_LANES_RUNTIME,
    areaCapacityBlocks: AREA_CAPACITY_BLOCKS_RUNTIME,
    defaultAreaCapacityBlocks: DEFAULT_AREA_CAPACITY_BLOCKS_RUNTIME
  });

  return new Response(html, {
    headers: { "Content-Type": "text/html; charset=UTF-8" }
  });
}

// ---------- API STAGE UPDATE ----------
if (url.pathname === "/api/stage-update" && request.method === "POST") {
  try {
    const body = await request.json();

    const booking_id = String(body.booking_id || "").trim();
    const date = String(body.date || "").trim();
    const stage = String(body.stage || "").trim().toLowerCase();
    const updated_by = String(body.updated_by || "").trim();

    const allowedStages = ["arrived", "done", "confirmed", "cancelled", "noshow"];

    if (!booking_id || !date || !stage) {
      return jsonResponse({
        success: false,
        error: "Missing booking_id, date or stage"
      }, 400, corsHeaders);
    }

    if (!allowedStages.includes(stage)) {
      return jsonResponse({
        success: false,
        error: "Invalid stage"
      }, 400, corsHeaders);
    }

    const outbound = {
      booking_id,
      date,
      stage,
      updated_by,
      worker_secret: env.WORKER_SECRET || "my-super-secret"
    };

    const baseUrl = (
      env.MAKE_STAGE_URL ||
      "https://hook.eu1.make.com/PUT_YOUR_STAGE_WEBHOOK_HERE"
    ).trim();

    const makeUrl = baseUrl + (baseUrl.includes("?") ? "&" : "?") + "_t=" + Date.now();

    const makeRes = await fetch(makeUrl, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(outbound)
    });

    const makeText = await makeRes.text();

    if (!makeRes.ok) {
      return jsonResponse({
        success: false,
        error: "Make rejected stage update",
        make_status: makeRes.status,
        make_response: makeText
      }, 502, corsHeaders);
    }

    return jsonResponse({
      success: true,
      accepted: true,
      message: "Stage update accepted by Make. Waiting for board sync.",
      make_status: makeRes.status,
      make_response: makeText
    }, 200, corsHeaders);

  } catch (e) {
    return jsonResponse({
      success: false,
      error: e.message || String(e),
      where: "/api/stage-update"
    }, 500, corsHeaders);
  }
}

    // ---------- DEFAULT ----------
    return new Response("Not found", { status:404 });

  }
};

function jsonResponse(data, status = 200, corsHeaders = {}) {
 return new Response(JSON.stringify(data), {
   status,
   headers: {
     ...corsHeaders,
     "Content-Type": "application/json"
   }
 });
}




