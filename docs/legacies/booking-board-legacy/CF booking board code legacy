  const durationMinutes = getBookingDurationMinutes(b);
  const x = minutesToX(startMinutes);
  const width = durationToWidth(durationMinutes);
  const tableCount = getBookingBlocks(b);


  const bar = document.createElement("div");
  bar.className = "booking-bar stage-" + (b.stage || "pending");
  bar.dataset.booking = JSON.stringify(b);
  if (b._localPending) bar.classList.add("local-pending");


  bar.style.left = x + "px";
  bar.style.width = width + "px";
  bar.style.backgroundColor = "var(--s-" + (b.stage || "pending") + ")";
if (b.stage === "done") {
  bar.style.opacity = "0.72";
}

if (b.stage === "cancelled" || b.stage === "noshow") {
  bar.style.opacity = "0.55";
  bar.style.filter = "grayscale(0.2)";
}

if (b.stage === "arrived") {
  bar.style.boxShadow = "0 0 0 2px rgba(255,255,255,0.15), 0 4px 10px rgba(0,0,0,0.35)";
}

  const fColor = b.flag ? "var(--f-" + b.flag + ")" : "transparent";
  const aColor = b.area ? "var(--a-" + b.area + ")" : "transparent";


  const partLabel =
    tableCount > 1
      ? ' <span style="opacity:0.75">(' + b._lanePart + '/' + b._laneTotal + ')</span>'
      : '';


  const stageLabelMap = {
  pending: "PENDING",
  confirmed: "CONFIRMED",
  arrived: "ARRIVED",
  done: "DONE",
  cancelled: "CANCELLED",
  noshow: "NO-SHOW"
};

const stageLabel = stageLabelMap[b.stage] || "PENDING";

const canArrive = b.stage === "confirmed";

bar.innerHTML =
  '<div class="flag-strip" style="background:' + fColor + '"></div>' +
  '<div class="area-underline" style="background:' + aColor + '"></div>' +
  '<div style="display:flex;justify-content:space-between;gap:8px;align-items:center;">' +
    '<div style="overflow:hidden; white-space:nowrap; text-overflow:ellipsis; min-width:0;">[' +
      escapeHtml(String(b.pax || "")) + 'p • ' + escapeHtml(String(tableCount)) + 'T] ' +
      escapeHtml(String(b.guest_name || "")) +
      partLabel +
    '</div>' +
    '<div style="font-size:0.62rem;padding:2px 6px;border-radius:999px;background:rgba(0,0,0,0.18);white-space:nowrap;">' +
      escapeHtml(stageLabel) +
    '</div>' +
  '</div>' +
  '<div style="font-size:0.68rem; opacity:0.85; white-space:nowrap; overflow:hidden; text-overflow:ellipsis">' +
    escapeHtml(String(b.time || "")) +
    ' • ' + durationMinutes + 'm' +
    (b.area ? ' • ' + escapeHtml(String(b.area)) : '') +
    (b._localPending ? ' • saving...' : '') +
  '</div>' +
  (canArrive
    ? '<button class="arrived-btn" ' +
        'data-booking-id="' + escapeHtml(String(b.booking_id || "")) + '" ' +
        'data-date="' + escapeHtml(String(b.date || "")) + '" ' +
        'style="position:absolute;right:6px;bottom:4px;padding:3px 8px;border:none;border-radius:999px;background:#ffffff;color:#111827;font-size:0.66rem;font-weight:700;cursor:pointer;z-index:20;">' +
        'Arrived' +
      '</button>'
    : '');
  
  return bar;
}


function toMinutes(timeStr) {
  if (!timeStr || !String(timeStr).includes(":")) return 0;
  const parts = String(timeStr).split(":").map(Number);
  return (parts[0] || 0) * 60 + (parts[1] || 0);
}


function getBookingStartMinutes(b) {
  return toMinutes(b.time || "00:00");
}


function getBookingDurationMinutes(b) {
  const d = Number(b.duration || b.duration_minutes || 120);
  return Number.isFinite(d) && d > 0 ? d : 120;
}


function getBookingEndMinutes(b) {
  return getBookingStartMinutes(b) + getBookingDurationMinutes(b);
}


function minutesToX(mins) {
  return (mins - DAY_START_HOUR * 60) * (PX_H / 60);
}


function durationToWidth(mins) {
  return mins * (PX_H / 60);
}


function closeModal() {
  document.getElementById("modalBooking").style.display = "none";
}


document.getElementById("bookingForm").onsubmit = async (e) => {
  e.preventDefault();

  const form = e.target;
  const fd = new FormData(form);
  fd.set("created_by", bookingCreator || "");

  const date = String(fd.get("date") || "");
  const time = String(fd.get("time") || "");

  if (isPastBooking(date, time)) {
    alert("Can't book the past.");
    return;
  }

  const optimisticPax = Number(fd.get("pax") || 0);

  const optimisticBooking = {
    guest_name: String(fd.get("guest_name") || ""),
    phone: String(fd.get("phone") || ""),
    pax: optimisticPax,
    blocks: Math.ceil(optimisticPax / 2),
    date: String(fd.get("date") || ""),
    time: String(fd.get("time") || ""),
    duration: Number(fd.get("duration") || 120),
    area: String(fd.get("area") || ""),
    flag: String(fd.get("flag") || ""),
    staff_user: String(fd.get("staff_user") || ""),
    stage: "sending",
    _localPending: true,
    _localId: "tmp_" + Date.now()
  };

  const sameDayBookings = dedupeBookingsForCapacity(serverBookings)
  .filter(b => b && b.date === optimisticBooking.date)
  .filter(b => isStillBlockingBooking(b));

  const capCheck = wouldExceedCapacity(optimisticBooking, sameDayBookings);

  if (capCheck.exceeds) {
    alert(
      "No more table capacity in " +
      (optimisticBooking.area || "this area") +
      " for that time slot."
    );
    return;
  }

  localPendingBookings.push(optimisticBooking);
  renderAllBookings();
  closeModal();

  try {
    const res = await fetch("/api/create?_t=" + Date.now(), {
      method: "POST",
      body: fd
    });

    const rawText = await res.text();
    let data = {};
    try {
      data = JSON.parse(rawText);
    } catch {
      data = { raw: rawText };
    }

    if (!res.ok || !data.success) {
      throw new Error(
        data.error ||
        data.make_response ||
        data.raw ||
        ("Create failed: " + res.status)
      );
    }

    // chờ Make sync ngược về KV
    let synced = false;
    for (let i = 0; i < 8; i++) {
      await new Promise(r => setTimeout(r, 1000));
      await loadData(selectedDate, true);

      synced = serverBookings.some(b =>
        b.guest_name === optimisticBooking.guest_name &&
        b.date === optimisticBooking.date &&
        b.time === optimisticBooking.time
      );

      if (synced) break;
    }

    localPendingBookings = localPendingBookings.filter(
      b => b._localId !== optimisticBooking._localId
    );
    renderAllBookings();

    if (!synced) {
      alert("Booking was accepted by Make, but has not appeared on the board yet.");
      return;
    }

    form.reset();
    document.getElementById("in_date").value = selectedDate;
    document.getElementById("in_duration").value = 120;

  } catch (err) {
    console.error("create booking error:", err);
    localPendingBookings = localPendingBookings.filter(
      b => b._localId !== optimisticBooking._localId
    );
    renderAllBookings();
    alert("Booking failed: " + (err.message || err));
  }
};


function toISODate(d) {
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return year + "-" + month + "-" + day;
}


function escapeHtml(str) {
  return String(str)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}


let currentPopupBookingId = null;


