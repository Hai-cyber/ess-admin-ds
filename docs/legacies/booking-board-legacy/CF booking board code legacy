<script>
let currentUser = "";
let bookingCreator = "";
let selectedDate = new Date().toISOString().split("T")[0];
let currentCalendarDate = new Date();
let serverBookings = [];
let localPendingBookings = [];


const PX_H = 120;
const DAY_START_HOUR = 10;
const DAY_END_HOUR = 24;
const MAX_LANES_LIMIT = ${maxVisualLanes};
const AREA_CAPACITY_BLOCKS = ${JSON.stringify(areaCapacityBlocks)};
const DEFAULT_AREA_CAPACITY_BLOCKS = ${defaultAreaCapacityBlocks};


function init() {
  buildRuler();
  buildLanes(1);
  buildCalendarDow();
  renderCalendar();
  updateClock();
  setupButtons();

  const authModal = document.getElementById("authModal");
  if (authModal) authModal.style.display = "none";

  currentUser = "";
  bookingCreator = "";

  const staffDropdown = document.getElementById("staffDropdown");
  if (staffDropdown) {
    staffDropdown.innerHTML = '<option value="">Select staff after PIN</option>';
  }

  setInterval(autoScrollToNow, 30000);
  setInterval(updateClock, 1000);
  updateSelectedDateLabel();
  setBookingMinDate();
  setTimeout(autoScrollToNow, 200);

  loadData(selectedDate, true);

  const refreshBtn = document.getElementById("refreshBoardBtn");
  if (refreshBtn) {
    refreshBtn.onclick = function () {
      loadData(selectedDate, true);
    };
  }
}


function setupButtons() {
  document.getElementById("btnNew").onclick = () => {
    openPinGateForBooking();
  };


  document.getElementById("btnBoard").onclick = () => {
    switchView("day");
  };


  document.getElementById("btnCal").onclick = () => {
    switchView("calendar");
  };


  document.getElementById("calPrev").onclick = () => {
    currentCalendarDate = new Date(
      currentCalendarDate.getFullYear(),
      currentCalendarDate.getMonth() - 1,
      1
    );
    renderCalendar();
  };


  document.getElementById("calNext").onclick = () => {
    currentCalendarDate = new Date(
      currentCalendarDate.getFullYear(),
      currentCalendarDate.getMonth() + 1,
      1
    );
    renderCalendar();
  };
}


function switchView(view) {
  document.getElementById("viewDay").classList.toggle("active", view === "day");
  document.getElementById("viewCalendar").classList.toggle("active", view === "calendar");
}


function updateSelectedDateLabel() {
  document.getElementById("selectedDateLabel").textContent = selectedDate;
}


function buildRuler() {
  const r = document.getElementById("ruler");
  r.innerHTML = "";
  for (let i = DAY_START_HOUR; i <= DAY_END_HOUR; i++) {
    const t = document.createElement("div");
    t.className = "hour-tick";
    t.style.left = ((i - DAY_START_HOUR) * PX_H) + "px";
    t.textContent = String(i).padStart(2, "0") + ":00";
    r.appendChild(t);
  }
}


function buildLanes(count) {
  const grid = document.getElementById("laneGrid");
  grid.innerHTML = "";
  const laneCount = Math.max(1, Math.min(count, MAX_LANES_LIMIT));


  for (let i = 1; i <= laneCount; i++) {
    const l = document.createElement("div");
    l.className = "lane";
    l.setAttribute("data-table", "T" + i);
    grid.appendChild(l);
  }
}


function buildCalendarDow() {
  const dow = document.getElementById("calendarDow");
  dow.innerHTML = "";
  ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"].forEach(d => {
    const el = document.createElement("div");
    el.className = "calendar-dow";
    el.textContent = d;
    dow.appendChild(el);
  });
}


function renderCalendar() {
  const grid = document.getElementById("calendarGrid");
  const title = document.getElementById("calendarTitle");
  grid.innerHTML = "";


  const y = currentCalendarDate.getFullYear();
  const m = currentCalendarDate.getMonth();


  title.textContent = currentCalendarDate.toLocaleDateString("en-GB", {
    month: "long",
    year: "numeric"
  });


  const firstDay = new Date(y, m, 1);
  let startWeekday = firstDay.getDay();
  startWeekday = startWeekday === 0 ? 7 : startWeekday;


  const gridStart = new Date(y, m, 1 - (startWeekday - 1));


  for (let i = 0; i < 42; i++) {
    const d = new Date(gridStart);
    d.setDate(gridStart.getDate() + i);


    const iso = toISODate(d);
    const cell = document.createElement("div");
    cell.className = "calendar-cell";
    if (d.getMonth() !== m) cell.classList.add("other-month");
    if (iso === selectedDate) cell.classList.add("selected");


    const isToday = iso === toISODate(new Date());


    cell.innerHTML =
      '<div class="calendar-date">' + d.getDate() + (isToday ? " • today" : "") + '</div>' +
      '<div class="calendar-meta">' + iso + '</div>' +
      '<div class="calendar-badge">Open board</div>';


    cell.onclick = () => {
      selectedDate = iso;
      updateSelectedDateLabel();
      switchView("day");
      loadData(selectedDate, true);
      renderCalendar();
    };


    grid.appendChild(cell);
  }
}


function setupAuth() {
  const pinInput = document.getElementById("pinInput");

  pinInput.addEventListener("input", async () => {
    if (pinInput.value.length !== 4) return;

    try {
      const r = await fetch("/api/auth?pin=" + encodeURIComponent(pinInput.value));
      const d = await r.json().catch(() => ({}));

      if (r.ok && d.success) {
        currentUser = d.user || "";
        document.getElementById("authModal").style.display = "none";
        populateStaff(d.staff || []);
        document.getElementById("in_date").value = selectedDate;
        loadData(selectedDate, true);
      } else {
        alert(
         "PIN failed.\\n" +
          "pin=" + (d.debug_pin || "") + "\\n" +
          "staff_count=" + (d.debug_staff_count ?? "?") + "\\n" +
          "env_present=" + (d.debug_env_present ?? "?")
          );
      }
    } catch (e) {
      alert("PIN check failed: " + (e.message || e));
      pinInput.value = "";
    }
  });
}


function populateStaff(list) {
  const s = document.getElementById("staffDropdown");
  if (!s) return;

  if (!Array.isArray(list) || list.length === 0) {
    s.innerHTML = '<option value="">Select staff after PIN</option>';
    return;
  }

  s.innerHTML = list.map(n =>
    '<option value="' + escapeHtml(n) + '" ' +
    (n === currentUser ? "selected" : "") +
    ">" + escapeHtml(n) + "</option>"
  ).join("");
}


function updateClock() {
  const n = new Date();
  document.getElementById("clock").textContent =
    n.getHours().toString().padStart(2, "0") + ":" +
    n.getMinutes().toString().padStart(2, "0");
}


function autoScrollToNow() {


  const container = document.getElementById("viewDay");
  if (!container) return;


  const now = new Date();


  const minutes =
    now.getHours() * 60 +
    now.getMinutes();


  const startMinutes = DAY_START_HOUR * 60;
  const endMinutes = DAY_END_HOUR * 60;


  if (minutes < startMinutes || minutes > endMinutes) return;


  const x = minutesToX(minutes);


  const viewportWidth = container.clientWidth;


  const target = x - viewportWidth * 0.30;


  container.scrollLeft = Math.max(0, target);
}


function isPastBooking(dateStr, timeStr) {
  if (!dateStr || !timeStr) return false;
  const dt = new Date(dateStr + "T" + timeStr);
  return dt.getTime() < Date.now();
}


function setBookingMinDate() {
  const now = new Date();
  const yyyy = now.getFullYear();
  const mm = String(now.getMonth() + 1).padStart(2, "0");
  const dd = String(now.getDate()).padStart(2, "0");
  document.getElementById("in_date").min = yyyy + "-" + mm + "-" + dd;
}


function openPinGateForBooking() {
  setBookingMinDate();
  bookingCreator = "";
  document.getElementById("bookingPinInput").value = "";
  document.getElementById("modalPinGate").style.display = "flex";
}


function closePinGate() {
  document.getElementById("modalPinGate").style.display = "none";
}

async function confirmBookingPin() {
  const pin = document.getElementById("bookingPinInput").value.trim();

  if (!pin) {
    alert("Please enter staff PIN.");
    return;
  }

  try {
    const r = await fetch("/api/auth?pin=" + encodeURIComponent(pin));
    const d = await r.json().catch(() => ({}));

    if (!r.ok || !d.success || !d.user) {
  alert(
    "Wrong PIN.\\n" +
    "pin=" + (d.debug_pin || "") + "\\n" +
    "staff_count=" + (d.debug_staff_count ?? "?")
  );
  return;
}

    bookingCreator = d.user || "";
    currentUser = d.user || "";

    const staffDropdown = document.getElementById("staffDropdown");
    if (staffDropdown) {
      staffDropdown.innerHTML =
        '<option value="' + bookingCreator.replace(/"/g, "&quot;") + '" selected>' +
        bookingCreator +
        '</option>';
      staffDropdown.value = bookingCreator;
    }

    closePinGate();
    document.getElementById("in_date").value = selectedDate;
    document.getElementById("in_duration").value = 120;
    document.getElementById("modalBooking").style.display = "flex";
  } catch (e) {
    console.error("confirmBookingPin failed", e);
    alert("PIN check failed: " + (e.message || e));
  }
}


function getBookingBlocks(b) {
  const pax = Number(b?.pax || 0);
  if (!Number.isFinite(pax) || pax <= 0) return 0;
  return Math.ceil(pax / 2);
}


function getAreaCapacityBlocks(area) {
  return AREA_CAPACITY_BLOCKS[area] || DEFAULT_AREA_CAPACITY_BLOCKS;
}


function bookingOverlapsMinute(booking, minute) {
  const start = getBookingStartMinutes(booking);
  const end = getBookingEndMinutes(booking);
  return start <= minute && minute < end;
}


function isStillBlockingBooking(booking) {
  if (!booking) return false;

  if (!isClosedStage(booking.stage)) return true;

  const ts = booking.updated_at || booking.submitted_at || "";
  if (!ts) return false;

  const t = new Date(ts).getTime();
  if (!Number.isFinite(t)) return false;

  const ageMs = Date.now() - t;
  return ageMs <= 10 * 60 * 1000; // chỉ block tối đa 10 phút
}

function shouldShowOnBoard(booking) {
  return isStillBlockingBooking(booking);
}

function getBlockUsageAtMinute(bookings, minute, area = "") {
  return bookings
    .filter(b => shouldBlockCapacity(b))
    .filter(b => !area || String(b.area || "") === String(area))
    .filter(b => bookingOverlapsMinute(b, minute))
    .reduce((sum, b) => sum + getBookingBlocks(b), 0);
}


function wouldExceedCapacity(newBooking, existingBookings) {
  const area = newBooking.area || "";
  const cap = getAreaCapacityBlocks(area);
  const newBlocks = getBookingBlocks(newBooking);


  const start = getBookingStartMinutes(newBooking);
  const end = getBookingEndMinutes(newBooking);


  for (let minute = start; minute < end; minute += 15) {
    const usage = getBlockUsageAtMinute(existingBookings, minute, area);
    if (usage + newBlocks > cap) {
      return {
        exceeds: true,
        minute: minute,
        usage: usage,
        cap: cap
      };
    }
  }


  return { exceeds: false };
}


function saveBoardCache(date, bookings) {
  const payload = {
    date: date,
    savedAt: new Date().toISOString(),
    bookings: bookings
  };
  localStorage.setItem("booking_cache_" + date, JSON.stringify(payload));
}


function loadBoardCache(date) {
  const raw = localStorage.getItem("booking_cache_" + date);
  if (!raw) return null;
  try {
    return JSON.parse(raw);
  } catch {
    return null;
  }
}


function setBoardStatus(label, text) {
  const badge = document.getElementById("dataStatusBadge");
  if (!badge) return;
  badge.textContent = label || "Idle";
  badge.title = text || "";
}

async function requireAccess(request) {
  const jwt = request.headers.get("Cf-Access-Jwt-Assertion");

  if (!jwt) {
    return {
      ok: false,
      reason: "Cloudflare Access required"
    };
  }

  return { ok: true };
}

function normalizeBooking(raw) {
  if (!raw || typeof raw !== "object") return null;

  const guest_name = String(
    raw.guest_name ??
    raw.contact_name ??
    raw.name ??
    ""
  ).trim();

  const date = String(raw.date || "").trim();

  const time = String(
    raw.time ??
    raw.start_at ??
    ""
  ).trim();

  const pax = Number(raw.pax ?? raw.guests ?? 0);
  const duration = Number(raw.duration ?? raw.duration_minutes ?? 120);

  const stage = String(raw.stage || "pending").trim().toLowerCase();
  const area = String(raw.area || "indoor").trim().toLowerCase();
  const flag = String(raw.flag || "").trim().toLowerCase();

  const staff_user =
    raw.staff != null
      ? String(raw.staff).trim()
      : (raw.staff_user != null ? String(raw.staff_user).trim() : "");

  if (!guest_name || !date || !time) return null;

  return {
    booking_id: String(raw.booking_id ?? raw.id ?? "").trim(),
    guest_name,
    contact_name: String(raw.contact_name ?? guest_name).trim(),
    phone: String(raw.phone || "").trim(),
    pax: Number.isFinite(pax) && pax > 0 ? pax : 0,
    blocks: Number(raw.blocks) > 0 ? Number(raw.blocks) : Math.max(1, Math.ceil((pax || 0) / 2)),
    date,
    time,
    start_at: String(raw.start_at ?? time).trim(),
    duration: Number.isFinite(duration) && duration > 0 ? duration : 120,
    area,
    flag,
    staff_user,
    staff: staff_user,
    stage,
    stage_id: Number(raw.stage_id || 0),
    notes: String(raw.notes || "").trim(),
    created_by: String(raw.created_by || "").trim(),
    updated_by: String(raw.updated_by || "").trim(),
    updated_at: String(raw.updated_at || "").trim(),
    submitted_at: String(raw.submitted_at || "").trim(),
    _localPending: !!raw._localPending,
    _localId: raw._localId ? String(raw._localId) : ""
  };
}

async function loadBookingsForDate(selectedDate) {
 const res = await fetch("/api/list?date=" + encodeURIComponent(selectedDate));
 if (!res.ok) throw new Error("Failed to load bookings: " + res.status);

  const data = await res.json();
  return Array.isArray(data) ? data : (data.bookings || []);
}

async function loadData(date = selectedDate, forceRefresh = false) {
  try {
    const cached = !forceRefresh ? loadBoardCache(date) : null;

    if (cached && cached.bookings) {
      serverBookings = cached.bookings
        .map(normalizeBooking)
        .filter(b => b && b.date === date);

      renderAllBookings();
      setBoardStatus("Cached", "Last update " + cached.savedAt);
      return;
    }

    setBoardStatus("Refreshing", "Loading latest bookings...");

    const bookings = await loadBookingsForDate(date);
    const normalized = bookings
      .map(normalizeBooking)
      .filter(b => b && b.date === date);

    serverBookings = normalized;

    saveBoardCache(date, normalized);

    renderAllBookings();
    setBoardStatus("Live", "Loaded " + normalized.length + " bookings");
  } catch (err) {
    console.error("loadData error:", err);

    const cached = loadBoardCache(date);
    if (cached && cached.bookings) {
      serverBookings = cached.bookings
        .map(normalizeBooking)
        .filter(b => b && b.date === date);

      renderAllBookings();
      setBoardStatus("Offline", "Showing cached data");
    } else {
      serverBookings = [];
      renderAllBookings();
      setBoardStatus("Error", err.message || String(err));
    }
  }
}


function shouldShowOnBoard(booking) {
  if (!booking) return false;

  if (!isClosedStage(booking.stage)) return true;

  const ts =
    booking.updated_at ||
    booking.submitted_at ||
    "";

  if (!ts) return false;

  const t = new Date(ts).getTime();
  if (!Number.isFinite(t)) return false;

  const ageMs = Date.now() - t;
  return ageMs <= 10 * 60 * 1000; // 10 phút
}
  
function getBookingIdentityKey(b) {
  const id = String(b?.booking_id || "").trim();
  if (id) return "id:" + id;

  // fallback nếu booking_id bị thiếu
  return [
    "fallback",
    String(b?.guest_name || "").trim().toLowerCase(),
    String(b?.date || "").trim(),
    String(b?.time || "").trim(),
    String(b?.phone || "").trim()
  ].join("|");
}

function dedupeBookingsForCapacity(bookings) {
  const map = new Map();

  for (const b of bookings || []) {
    if (!b) continue;

    const key = getBookingIdentityKey(b);
    const prev = map.get(key);

    if (!prev) {
      map.set(key, b);
      continue;
    }

    const prevTs = new Date(prev.updated_at || prev.submitted_at || 0).getTime() || 0;
    const currTs = new Date(b.updated_at || b.submitted_at || 0).getTime() || 0;

    // ưu tiên bản mới hơn
    if (currTs >= prevTs) {
      map.set(key, b);
    }
  }

  return Array.from(map.values());
}

function dedupeBookingsById(bookings) {
  const map = new Map();

  for (const b of bookings) {
    if (!b) continue;

    const key = String(b.booking_id || "").trim();
    if (!key) continue;

    const prev = map.get(key);
    if (!prev) {
      map.set(key, b);
      continue;
    }

    const prevTs = new Date(prev.updated_at || prev.submitted_at || 0).getTime() || 0;
    const currTs = new Date(b.updated_at || b.submitted_at || 0).getTime() || 0;

    if (currTs >= prevTs) {
      map.set(key, b);
    }
  }

  return Array.from(map.values());
}

function isClosedStage(stage) {
  const s = String(stage || "").trim().toLowerCase();
  return s === "done" || s === "cancelled" || s === "noshow";
}

function shouldBlockCapacity(booking) {
  if (!booking) return false;

  // booking đã đóng thì giải phóng block NGAY LẬP TỨC
  if (isClosedStage(booking.stage)) return false;

  return true;
}

function shouldShowOnBoard(booking) {
  if (!booking) return false;

  // booking còn active thì luôn hiện
  if (!isClosedStage(booking.stage)) return true;

  // booking đóng thì chỉ hiện thêm 5 phút để staff nhìn
  const ts = booking.updated_at || booking.submitted_at || "";
  if (!ts) return false;

  const t = new Date(ts).getTime();
  if (!Number.isFinite(t)) return false;

  const ageMs = Date.now() - t;
  return ageMs <= 5 * 60 * 1000;
}

function isStillBlockingBooking(booking) {
  if (!booking) return false;

  if (!isClosedStage(booking.stage)) return true;

  const ts = booking.updated_at || booking.submitted_at || "";
  if (!ts) return false;

  const t = new Date(ts).getTime();
  if (!Number.isFinite(t)) return false;

  const ageMs = Date.now() - t;
  return ageMs <= 10 * 60 * 1000;
}

function shouldShowOnBoard(booking) {
  return isStillBlockingBooking(booking);
}

function renderAllBookings() {
  const merged = dedupeBookingsForCapacity([
    ...serverBookings,
    ...localPendingBookings
  ]);

  const combined = merged.filter(
    b => b && b.date === selectedDate && shouldShowOnBoard(b)
  );

  const result = assignLanesByOverlap(combined);

  buildLanes(result.laneCount);

  const lanes = document.querySelectorAll(".lane");
  for (const b of result.placed) {
    if (b._laneIndex >= lanes.length) continue;
    const bar = createBarElement(b);
    lanes[b._laneIndex].appendChild(bar);
  }

  attachBookingPopupEvents();
  attachArrivedButtonEvents();
}


function assignLanesByOverlap(bookings) {
  const sorted = [...bookings].sort((a, b) => {
    const sa = getBookingStartMinutes(a);
    const sb = getBookingStartMinutes(b);
    if (sa !== sb) return sa - sb;


    const ea = getBookingEndMinutes(a);
    const eb = getBookingEndMinutes(b);
    if (ea !== eb) return ea - eb;


    return getBookingBlocks(b) - getBookingBlocks(a);
  });


  const laneEndTimes = [];
  const placed = [];


  for (const booking of sorted) {
    const start = getBookingStartMinutes(booking);
    const end = getBookingEndMinutes(booking);
    const blocksNeeded = Math.max(1, getBookingBlocks(booking));


    let startLane = -1;


    for (let i = 0; i <= laneEndTimes.length; i++) {
      let canFit = true;


      for (let j = 0; j < blocksNeeded; j++) {
        const laneIndex = i + j;
        const laneEnd = laneEndTimes[laneIndex] || 0;
        if (start < laneEnd) {
          canFit = false;
          break;
        }
      }


      if (canFit) {
        startLane = i;
        break;
      }
    }


    if (startLane === -1) {
      startLane = laneEndTimes.length;
    }


    for (let j = 0; j < blocksNeeded; j++) {
      const laneIndex = startLane + j;
      laneEndTimes[laneIndex] = end;


      placed.push({
        ...booking,
        _laneIndex: laneIndex,
        _lanePart: j + 1,
        _laneTotal: blocksNeeded
      });
    }
  }


  return {
    placed: placed,
    laneCount: Math.max(1, Math.min(laneEndTimes.length, MAX_LANES_LIMIT))
  };
}


function createBarElement(b) {
