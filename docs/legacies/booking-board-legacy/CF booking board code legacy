function hideBookingPopup() {
  const popup = document.getElementById("bookingPopup");
  if (!popup) return;
  popup.style.display = "none";
  currentPopupBookingId = null;
}


function showBookingPopup(booking, anchorEl) {
  const popup = document.getElementById("bookingPopup");
  const content = document.getElementById("bookingPopupContent");
  if (!popup || !content || !anchorEl) return;


  content.innerHTML = formatBookingPopupHtml(booking);
  popup.style.display = "block";


  const rect = anchorEl.getBoundingClientRect();
  popup.style.left = "0px";
  popup.style.top = "0px";


  requestAnimationFrame(() => {
    const popupRect = popup.getBoundingClientRect();
    const gap = 10;


    let left = rect.right + gap;
    let top = rect.top;


    if (left + popupRect.width > window.innerWidth - 12) {
      left = rect.left - popupRect.width - gap;
    }


    if (left < 12) left = 12;


    if (top + popupRect.height > window.innerHeight - 12) {
      top = window.innerHeight - popupRect.height - 12;
    }


    if (top < 12) top = 12;


    popup.style.left = left + "px";
    popup.style.top = top + "px";
  });


  currentPopupBookingId = booking.booking_id || booking.id || null;
}


function attachBookingPopupEvents() {
  document.querySelectorAll(".booking-bar").forEach(el => {
    if (el.dataset.popupBound === "1") return;
    el.dataset.popupBound = "1";


    el.addEventListener("click", (ev) => {
      ev.stopPropagation();


      let booking = null;
      try {
        booking = JSON.parse(el.dataset.booking || "{}");
      } catch {
        booking = {};
      }


      const clickedId = booking.booking_id || booking.id || null;


      if (currentPopupBookingId && clickedId === currentPopupBookingId) {
        hideBookingPopup();
        return;
      }


      showBookingPopup(booking, el);
    });
  });
}

function attachArrivedButtonEvents() {
  document.querySelectorAll(".arrived-btn").forEach(btn => {
    if (btn.dataset.bound === "1") return;
    btn.dataset.bound = "1";

    btn.addEventListener("click", async (ev) => {
      ev.stopPropagation();

      const bookingId = String(btn.dataset.bookingId || "").trim();
      const date = String(btn.dataset.date || "").trim();

      if (!bookingId || !date) {
        alert("Missing booking id or date.");
        return;
      }

      btn.disabled = true;
      btn.textContent = "Sending...";

      try {
        // optimistic UI
        const target = serverBookings.find(b => String(b.booking_id) === bookingId && b.date === date);
        if (target) {
          target.stage = "arrived";
          target.updated_by = currentUser || bookingCreator || "";
          target.updated_at = new Date().toISOString();
          renderAllBookings();
        }
                  // patch local KV projection ngay để board không bị chờ Make quá lâu
        await fetch("/api/board-sync?_t=" + Date.now(), {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            ...(target || {
              booking_id: bookingId,
              date: date,
              stage: "arrived",
              updated_by: currentUser || bookingCreator || "",
              updated_at: new Date().toISOString()
            })
          })
        });

        const res = await fetch("/api/stage-update?_t=" + Date.now(), {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            booking_id: bookingId,
            date: date,
            stage: "arrived",
            updated_by: currentUser || bookingCreator || ""
          })
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.success) {
          throw new Error(data.error || data.make_response || ("Stage update failed: " + res.status));
        }

        // poll cho tới khi Make sync ngược về board KV
        let synced = false;
        for (let i = 0; i < 8; i++) {
          await new Promise(r => setTimeout(r, 1000));
          await loadData(selectedDate, true);

          const updated = serverBookings.find(
            b => String(b.booking_id) === bookingId && b.date === date
          );

          if (updated && updated.stage === "arrived") {
            synced = true;
            break;
          }
        }

        if (!synced) {
          alert("Arrived accepted, but board sync has not returned yet.");
        }

      } catch (err) {
        console.error("arrived update error:", err);
        await loadData(selectedDate, true);
        alert("Arrived failed: " + (err.message || err));
      } finally {
        await loadData(selectedDate, true);
      }
    });
  });
}


document.addEventListener("click", (ev) => {
  const popup = document.getElementById("bookingPopup");
  if (!popup) return;


  const clickedInsidePopup = popup.contains(ev.target);
  const clickedBooking = ev.target.closest(".booking-bar");


  if (!clickedInsidePopup && !clickedBooking) {
    hideBookingPopup();
  }
});


document.addEventListener("keydown", (ev) => {
  if (ev.key === "Escape") hideBookingPopup();
});

