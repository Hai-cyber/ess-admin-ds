{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tenant-config.schema.json",
  "title": "Tenant Config",
  "type": "object",
  "required": ["company_id", "operations", "staff_policy", "social", "media"],
  "properties": {
    "company_id": { "type": "integer", "minimum": 1 },
    "operations": {
      "type": "object",
      "required": ["business_hours_open", "business_hours_close", "capacities"],
      "properties": {
        "business_hours_open": { "type": "string" },
        "business_hours_close": { "type": "string" },
        "closed_weekday": { "type": "string" },
        "min_booking_advance_min": { "type": "integer", "minimum": 0 },
        "default_booking_duration": { "type": "integer", "minimum": 15 },
        "capacities": {
          "type": "object",
          "properties": {
            "indoor": { "type": "integer", "minimum": 0 },
            "outdoor": { "type": "integer", "minimum": 0 },
            "garden": { "type": "integer", "minimum": 0 },
            "bar": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": true
    },
    "staff_policy": {
      "type": "object",
      "properties": {
        "allow_pin_login": { "type": "boolean" },
        "max_staff": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "social": {
      "type": "object",
      "properties": {
        "facebook_url": { "type": "string" },
        "instagram_url": { "type": "string" },
        "tiktok_url": { "type": "string" },
        "youtube_url": { "type": "string" },
        "facebook_app_id": { "type": "string" },
        "google_client_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "media": {
      "type": "object",
      "properties": {
        "uploads_enabled": { "type": "boolean" },
        "max_asset_mb": { "type": "integer", "minimum": 1 },
        "allowed_types": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
